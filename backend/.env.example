# 서버
NODE_ENV=development
PORT=5000
PUBLIC_SITE_URL=http://localhost:5000
WGS_TRUST_PROXY=true
CORS_ALLOWED_ORIGINS=http://localhost:5000,http://127.0.0.1:5000,https://woogongsil.site,https://www.woogongsil.site
WGS_ROBOTS_NOINDEX=true

# 데이터베이스
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=exam_bank
DB_CONNECTION_LIMIT=10

# 입장 인증 / 초대 코드
INVITE_CODE=
INVITE_TOKEN_SECRET=
INVITE_TOKEN_MAX_AGE_DAYS=30

# hCaptcha 설정
HCAPTCHA_ENABLED=false
HCAPTCHA_SITE_KEY=
HCAPTCHA_SECRET_KEY=
HCAPTCHA_REQUIRED_ACTIONS=
HCAPTCHA_TRUST_GATEKEEPER=true

# 관리자 / 결재
WGS_ADMIN_USER_ID=
ADMIN_APPROVAL_BYPASS_TOKEN=
SIGNUP_ADMIN_NOTIFY_EMAIL=

# 요청 제한
WGS_RATE_LIMIT_ENABLED=true
WGS_LIMIT_CLIENT_GATEKEEPER_PER_MIN=8
WGS_LIMIT_IP_GATEKEEPER_PER_MIN=80
WGS_LIMIT_CLIENT_LOGIN_PER_MIN=8
WGS_LIMIT_ACCOUNT_LOGIN_PER_10MIN=10
WGS_LIMIT_IP_LOGIN_PER_MIN=60
WGS_LIMIT_CLIENT_REGISTER_PER_10MIN=10
WGS_LIMIT_EMAIL_REGISTER_PER_10MIN=8
WGS_LIMIT_IP_REGISTER_PER_10MIN=30
WGS_LIMIT_CLIENT_FIND_ACCOUNT_PER_10MIN=8
WGS_LIMIT_EMAIL_FIND_ACCOUNT_PER_10MIN=8
WGS_LIMIT_IP_FIND_ACCOUNT_PER_10MIN=30
WGS_LIMIT_CLIENT_CHANGE_PW_PER_10MIN=8
WGS_LIMIT_EMAIL_CHANGE_PW_PER_10MIN=8
WGS_LIMIT_IP_CHANGE_PW_PER_10MIN=30
WGS_LIMIT_CLIENT_CONTENT_VIEW_PER_MIN=120
WGS_LIMIT_IP_CONTENT_VIEW_PER_MIN=300
WGS_LIMIT_CLIENT_NOTIFY_EMAIL_PER_10MIN=10
WGS_LIMIT_USER_NOTIFY_EMAIL_PER_10MIN=10
WGS_LIMIT_IP_NOTIFY_EMAIL_PER_10MIN=40
WGS_LIMIT_CLIENT_API_WRITE_PER_MIN=120
WGS_LIMIT_USER_API_WRITE_PER_MIN=180
WGS_LIMIT_SESSION_API_WRITE_PER_MIN=180
WGS_LIMIT_IP_API_WRITE_PER_MIN=600
WGS_LIMIT_USER_ADMIN_WRITE_PER_MIN=60
WGS_LIMIT_SESSION_ADMIN_WRITE_PER_MIN=90
WGS_LIMIT_IP_ADMIN_WRITE_PER_MIN=240

# 카카오
KAKAO_MAP_JS_KEY=
KAKAO_REST_API_KEY=

# 메일
MAIL_USER=
MAIL_APP_PASSWORD=
